msgstr "Trình hướng dẫn tập lệnh người dùng"

msgid "Hint: You do not need to save anything in the settings. Select the actions and click the Generate button."
msgstr "Gợi ý: Bạn không cần lưu bất cứ điều gì trong cài đặt. Chọn các hành động và nhấp vào nút Tạo."

msgid "modem restart"
msgstr "khởi động lại modem"

msgid "reboot"
msgstr "khởi động lại thiết bị"

msgid "Restart modem if restarting the interfaces did not restore internet access."
msgstr "Khởi động lại modem nếu khởi động lại giao diện không khôi phục được truy cập Internet."

msgid "Router reboot if restarting the interfaces did not restore internet access."
msgstr "Khởi động lại bộ định tuyến nếu khởi động lại giao diện không khôi phục được truy cập Internet."

